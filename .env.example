# Rulecraft Environment Configuration

# Database
DATABASE_URL=sqlite:./rulecraft.db

# Server
PORT=3000

# Claude API (for AI rulings)
# Get your key from https://console.anthropic.com
CLAUDE_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Admin API Key (REQUIRED for production)
# Used to protect POST /api/rules endpoint
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Rate Limiting
# AI endpoint (/scenario/ask) - requests per hour per IP
AI_RATE_LIMIT_PER_HOUR=5
# Search endpoints - requests per minute per IP
SEARCH_RATE_LIMIT_PER_MINUTE=30

# Logging
# Use "rulecraft=debug,tower_http=debug" for verbose output
RUST_LOG=rulecraft=info,tower_http=info

# Vector Search (optional, for Qdrant)
# QDRANT_URL=http://localhost:6333
